#!/usr/bin/env python3
"""Pequeño lanzador ejecutable para UniHorario.

Este script se instala en `build/` y ejecuta la aplicación de escritorio
de forma portátil (requiere Python 3 y dependencias instaladas).
"""
import os
import sys
import subprocess

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.normpath(os.path.join(HERE, '..'))
LAUNCHER = os.path.join(ROOT, 'launcher_desktop.py')

if __name__ == '__main__':
    if not os.path.exists(LAUNCHER):
        print('Error: no se encontró launcher_desktop.py en el directorio del proyecto.', file=sys.stderr)
        sys.exit(2)
    # Ejecutar con el mismo intérprete que usa este script
    args = [sys.executable, LAUNCHER] + sys.argv[1:]
    try:
        ret = subprocess.call(args)
        sys.exit(ret)
    except KeyboardInterrupt:
        sys.exit(1)
